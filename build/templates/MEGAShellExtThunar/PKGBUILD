pkgname=thunar-megasync
pkgver=EXT_VERSION
pkgrel=`cat MEGA_BUILD_ID || echo "1"`
epoch=
pkgdesc="MEGA Desktop App plugin for Thunar"
arch=('i686' 'x86_64')
url="https://mega.io/desktop"
license=() #TODO
depends=('thunar' 'megasync>=5.3.0')
makedepends=('ca-certificates' 'cmake')
provides=("thunar-megasync=${pkgver}")
conflicts=()
replaces=()
backup=()
options=()
install=thunarext.install
changelog= #TODO
source=("./${pkgname}_$pkgver.tar.gz")
noextract=()
md5sums=('MD5SUM')
validpgpkeys=()

build() {
	cmake -B build -S "$pkgname-$pkgver" \
		-DCMAKE_INSTALL_PREFIX='/usr'
    cmake --build build ${BUILD_PARALLEL_JOBS}
}

check() {
	cd "$pkgname-$pkgver"
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

